# ----------------------------------------------------
# DATABASE
# ----------------------------------------------------
# This matches the default docker-compose.yml configuration
DATABASE_URL="postgresql://admin:password123@localhost:5432/compliance_saas?schema=public"

# ----------------------------------------------------
# REDIS / BULLMQ
# ----------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT=6379

# ----------------------------------------------------
# AUTHENTICATION
# ----------------------------------------------------
JWT_SECRET="super_secret_key_change_in_production"
PORT=3000

# ----------------------------------------------------
# STORAGE (CLOUDFLARE R2 / AWS S3)
# ----------------------------------------------------
R2_ENDPOINT="https://<YOUR_ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="compliance-docs"
R2_PUBLIC_URL="https://pub-xxxxxx.r2.dev"

# ----------------------------------------------------
# AI INTELLIGENCE (GOOGLE GEMINI)
# ----------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"

# ----------------------------------------------------
# BILLING (RAZORPAY)
# ----------------------------------------------------
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ----------------------------------------------------
# NOTIFICATIONS (MOCK)
# ----------------------------------------------------
EMAIL_SMTP_HOST="smtp.mailtrap.io"
EMAIL_SMTP_PORT=2525
EMAIL_SMTP_USER="user"
EMAIL_SMTP_PASS="pass"
